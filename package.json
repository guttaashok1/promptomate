{
  "name": "promptomate",
  "version": "0.1.0",
  "description": "Prompt-driven Playwright test generation with self-healing locators, visual assertions, and auto-triage, powered by Claude.",
  "keywords": [
    "playwright",
    "testing",
    "e2e",
    "ai",
    "claude",
    "anthropic",
    "mcp",
    "qa",
    "automation",
    "self-healing"
  ],
  "license": "MIT",
  "author": "ashokkumargutta",
  "homepage": "https://github.com/guttaashok1/promptomate#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guttaashok1/promptomate.git"
  },
  "bugs": {
    "url": "https://github.com/guttaashok1/promptomate/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "promptomate": "dist/cli.js"
  },
  "files": [
    "dist/",
    "public/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && cp -r public dist/ 2>/dev/null || true",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js serve",
    "postinstall": "playwright install chromium-headless-shell || true",
    "test": "playwright test",
    "test:unit": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@playwright/mcp": "^0.0.70",
    "@playwright/test": "^1.50.0",
    "commander": "^13.0.0",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "posthog-node": "^5.29.2",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.0",
    "@types/prompts": "^2.4.9",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.4"
  }
}
